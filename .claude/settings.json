{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(turbo *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env*.local)"
    ]
  },
  "hooks": {
    "TaskCompleted": [{
      "hooks": [{
        "type": "command",
        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-task.sh",
        "timeout": 120
      }]
    }],
    "TeammateIdle": [{
      "hooks": [{
        "type": "command",
        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-idle.sh"
      }]
    }],
    "Stop": [{
      "hooks": [{
        "type": "prompt",
        "prompt": "檢查：1. `pnpm test` 通過 2. 變更已 commit 3. 若完成非 trivial 功能需更新 docs/architecture-journal.md",
        "timeout": 30
      }]
    }]
  }
}
