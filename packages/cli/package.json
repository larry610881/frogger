{
  "name": "@frogger/cli",
  "version": "0.1.9",
  "type": "module",
  "bin": {
    "frogger": "./bin/frogger.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@frogger/core": "workspace:*",
    "@frogger/shared": "workspace:*",
    "ai": "^6.0.116",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14"
  }
}
