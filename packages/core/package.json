    "@ai-sdk/provider": "^3.0.8",
    "@frogger/shared": "workspace:*",
    "ai": "^6.0.116",
    "diff-match-patch": "^1.0.5",
    "execa": "^9.6.1",
    "globby": "^16.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^25.3.5"
